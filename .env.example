# The base URL of your Lovable Cloud project's document-worker Edge Function.
# Format: https://<your-project-ref>.supabase.co/functions/v1/document-worker
WORKER_URL=https://YOUR-PROJECT-REF.supabase.co/functions/v1/document-worker

# Shared secret. Must match the DOCUMENT_WORKER_KEY stored in Lovable Cloud → Backend → Secrets.
DOCUMENT_WORKER_KEY=paste-the-secret-here

# Stable identifier for this worker instance. Pick something recognisable.
WORKER_ID=worker-local-01

# How often (ms) to poll for new jobs when the queue is empty.
POLL_INTERVAL_MS=5000

# How often (ms) to send heartbeats while processing.
HEARTBEAT_INTERVAL_MS=45000

# Chunking + embedding tuning
CHUNK_SIZE=1200
CHUNK_OVERLAP=150
CHUNKS_PER_BATCH=32

# Embedding provider.
# "mock"   → generates deterministic 1536-dim vectors (good for first run, no cost).
# "openai" → uses OpenAI text-embedding-3-small (requires OPENAI_API_KEY).
EMBED_PROVIDER=mock
OPENAI_API_KEY=
